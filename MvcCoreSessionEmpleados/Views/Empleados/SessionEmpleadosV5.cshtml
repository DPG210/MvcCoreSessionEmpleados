
@model List<Empleado>

@{
    //NECESITAMOS SESSION EN LA VISTA PARA COMPROBAR SUS DATOS
    List<int> ids = Context.Session.GetObject<List<int>>("IDSEMPLEADOS");
    List<Empleado> favoritos = memoryCache.Get<List<Empleado>>("FAVORITOS");
}

<h1 style="color:burlywood">Session empleados Ok List V5</h1>

@if (ids != null)
{
    <h3 style="background-color:lightgreen">Empleados Session: @ids.Count</h3>
}
else
{
    <h3 style="background-color:lightgreen">Empleados Session: 0</h3>
}
@if(favoritos != null)
{
    <h3 style="background-color:fuchsia">Favoritos:@favoritos.Count</h3>
}
else
{
    <h3 style="background-color:fuchsia">Favoritos:0</h3>
}
<p>
    <a asp-controller="Empleados"
       asp-action="EmpleadosAlmacenadosV5">
        Empleados V5
    </a>
</p>
<p>
    <a asp-controller="Empleados"
       asp-action="EmpleadosFavoritos">
        Empleados Favoritos V5
    </a>
</p>
<h4 style="color:green">@ViewData["MENSAJE"]</h4>
<ul class="list-group">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item">
            @empleado.Apellido
            <a asp-controller="Empleados" 
            asp-action="SessionEmpleadosV5" 
            asp-route-idfavorito="@empleado.IdEmpleado">
                Favorito
            </a>
            @*PREGUNTAMOS SI EXISTE EL EMPLEADO EN SESSION*@
            @if (ids == null)
            {
                //NO TENEMOS SESSION
                <a asp-controller="Empleados"
                   asp-action="SessionEmpleadosV5"
                   asp-route-idempleado="@empleado.IdEmpleado">
                    Almacenar Empleado
                </a>
            }
            else
            {
                //BUSCAMOS SI EL EMPLEADO QUE ESTAMOS RECORRIENDO EXISTE EN LA SESSION
                if(ids.Contains(empleado.IdEmpleado))
                {
                    <img src="~/images/expedition.jpg" style="width:40px;height:40px" />
                }
                else
                {
                    <a asp-controller="Empleados"
                       asp-action="SessionEmpleadosV5"
                       asp-route-idempleado="@empleado.IdEmpleado">
                        Almacenar Empleado
                    </a>
                }
            }
        </li>
    }
</ul>