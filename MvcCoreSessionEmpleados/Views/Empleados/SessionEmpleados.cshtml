@model List<Empleado>

<h1>Session empleados List</h1>

<p>
    <a asp-controller="Empleados"
       asp-action="EmpleadosAlmacenados">
        Empleados Almacenados
    </a>
</p>
<h4 style="color:blue">@ViewData["MENSAJE"]</h4>
<ul class="list-group">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item">
            @empleado.Apellido
            <a asp-controller="Empleados"
               asp-action="SessionEmpleados"
               asp-route-idempleado="@empleado.IdEmpleado">
                Almacenar Empleado
            </a>
        </li>
    }
</ul>