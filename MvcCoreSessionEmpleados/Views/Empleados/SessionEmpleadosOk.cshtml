@model List<Empleado>

<h1>Session empleados Ok List</h1>

<p>
    <a asp-controller="Empleados"
       asp-action="EmpleadosAlmacenadosOk">
        Empleados Almacenados Ok
    </a>
</p>
<h4 style="color:green">@ViewData["MENSAJE"]</h4>
<ul class="list-group">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item">
            @empleado.Apellido
            <a asp-controller="Empleados"
               asp-action="SessionEmpleadosOk"
               asp-route-idempleado="@empleado.IdEmpleado">
                Almacenar Empleado
            </a>
        </li>
    }
</ul>