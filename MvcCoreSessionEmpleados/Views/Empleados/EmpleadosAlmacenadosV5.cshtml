@model List<Empleado>
<h1 style="color:burlywood">
    Empleados almacenados Ok V5
</h1>
<p>
    <a asp-controller="Empleados"
       asp-action="SessionEmpleadosV5">
        Volver a empleados
    </a>
</p>

@if (Context.Session.GetString("IDSEMPLEADOS") == null)
{
    <h1>No existen empleados</h1>
}

else{
@if (Model != null)
{
    @if (Model != null)
    {
        <table class="table table-striped-columns">
            <thead>
                <tr>
                    <th>
                        Id
                    </th>
                    <th>
                        Apellido
                    </th>
                    <th>
                        Oficio
                    </th>
                    <th>
                        Salario
                    </th>
                    <th>
                        IdDepartamento
                    </th>
                    <th>
                        Eliminar
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @item.IdEmpleado
                        </td>
                        <td>
                            @item.Apellido
                        </td>
                        <td>
                            @item.Oficio
                        </td>
                        <td>
                            @item.Salario
                        </td>
                        <td>
                            @item.IdDepartamento
                        </td>
                        <td>
                            <a asp-controller="Empleados"
                               asp-action="EmpleadosAlmacenadosV5"
                               asp-route-ideliminar="@item.IdEmpleado">
                                Eliminar empleado
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
}